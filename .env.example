# Claude-Skill-Definer environment config
# Copy to .env (gitignored) and fill in.

# Public plugin marketplace
CSD_PUBLIC_MARKETPLACE_URL=https://github.com/danielrosehill/<public-marketplace-repo>
CSD_PUBLIC_MARKETPLACE_PATH=/home/daniel/repos/github/my-repos/<public-marketplace-repo>

# Private plugin marketplace
CSD_PRIVATE_MARKETPLACE_URL=https://github.com/danielrosehill/<private-marketplace-repo>
CSD_PRIVATE_MARKETPLACE_PATH=/home/daniel/repos/github/my-repos/<private-marketplace-repo>

# Data dir for cached indexes (default: ~/.local/share/claude-skill-definer)
# CSD_DATA_DIR=/home/daniel/.local/share/claude-skill-definer
